DATABASE_URL="postgresql://user:password@localhost:5432/flower_aggregator"
JWT_SECRET="change-me"
NODE_ENV=development

# Frontend URL (ссылки в письмах и клики в push)
APP_URL=http://localhost:3000

# Web Push (сгенерировать: node scripts/generate-vapid-keys.mjs)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Production: URL фронта (можно несколько через запятую)
# CORS_ORIGIN=https://flower-web.onrender.com
CORS_ORIGIN=http://localhost:3000

# Email (опционально; без SMTP письма логируются в консоль сервера)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FlowerShop <noreply@example.com>
